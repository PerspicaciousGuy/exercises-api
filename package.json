{
  "name": "exercisedb-api",
  "version": "0.1.0",
  "description": "Production-grade public exercise catalog API for fitness app developers.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "fixtures:validate": "node scripts/validate-fixtures.js",
    "seed:reference": "node scripts/seed-reference-data.js",
    "seed:sample": "node scripts/import-sample-exercises.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "exercise",
    "fitness",
    "api",
    "catalog",
    "sync"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
