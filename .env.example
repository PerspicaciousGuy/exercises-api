NODE_ENV=development
PORT=3000
SERVICE_NAME=exercisedb-api
API_VERSION=0.1.0

# fatal | error | warn | info | debug | trace | silent
# Pretty-printed in development, JSON everywhere else. Forced to `silent`
# under NODE_ENV=test.
LOG_LEVEL=info

# Origins allowed to send the dashboard session cookie, comma separated.
# Only these may call /auth, /me, and /billing with credentials; the public
# catalog stays open to every origin. Set this to the deployed dashboard URL
# in production.
DASHBOARD_ORIGINS=http://localhost:5173

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Lemon Squeezy billing. Required only for /billing/checkout and the webhook
# endpoint; the catalog and sync APIs boot without them.
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_VARIANT_ID_BASIC=
LEMON_SQUEEZY_VARIANT_ID_PRO=
LEMON_SQUEEZY_VARIANT_ID_ENTERPRISE=
